# Production env for docker-compose.prod.yml.
# Copy to .env on the server (or store the whole file as the ENV_FILE GitHub
# secret used by the deploy workflow).

# --- Web build (baked into the JS bundle at docker build time) ---
# Must include the /api prefix — the client appends paths like /feed, /image.
EXPO_PUBLIC_API_URL=https://flowpedia-api.julsql.fr/api

# --- Host ports (loopback only; the host nginx reverse-proxies these) ---
WEB_PORT=8110
API_PORT=8111

# --- API ---
# Required by Wikimedia — use a valid contact.
WIKIPEDIA_USER_AGENT=Flowpedia/0.1 (https://flowpedia.julsql.fr; contact@flowpedia.julsql.fr)
WIKIPEDIA_LANG=fr
ARTICLE_CACHE_TTL=86400

# --- Postgres (user-signal persistence) ---
POSTGRES_USER=flowpedia
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=flowpedia

# --- Auth (accounts) ---
# MUST be a long random string in production (tokens are forgeable otherwise).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
# Web origin of the app — where the /reset/<uid>/<token> screen is served, so the
# emailed reset link opens it (NOT the API origin).
APP_URL=https://flowpedia.julsql.fr

# --- Email reset (Gmail SMTP) ---
# Leave USER/PASSWORD empty to log reset links to the console instead of sending.
# For real emails: a Gmail address + a Gmail *app password*
# (https://myaccount.google.com/apppasswords — not the login password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
