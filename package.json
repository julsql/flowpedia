{
  "name": "flowpedia",
  "version": "0.1.0",
  "private": true,
  "description": "Flowpedia — a social-style feed of Wikipedia articles",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "api": "pnpm --filter @flowpedia/api start:dev",
    "mobile": "pnpm --filter @flowpedia/mobile start",
    "mobile:clear": "pnpm --filter @flowpedia/mobile start:clear",
    "mobile:web": "pnpm --filter @flowpedia/mobile web",
    "mobile:android": "pnpm --filter @flowpedia/mobile android",
    "build:shared": "pnpm --filter @flowpedia/shared build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "test": "pnpm -r test"
  }
}
