# API HTTP port
PORT=3000

# User-Agent required by Wikimedia (use a valid contact)
WIKIPEDIA_USER_AGENT=Flowpedia/0.1 (https://github.com/JulSql/flowpedia; contact@flowpedia.app)

# Default Wikipedia content language (overridable per request via ?lang=)
WIKIPEDIA_LANG=fr

# Article cache TTL in seconds
ARTICLE_CACHE_TTL=86400

# Connections (next steps)
DATABASE_URL=postgresql://flowpedia:flowpedia@localhost:5433/flowpedia
REDIS_URL=redis://localhost:6379

# Auth — bearer token signing (CHANGE in production)
JWT_SECRET=flowpedia-dev-secret-change-me
JWT_EXPIRES_IN=30d
# Base URL used to build the password-reset link in emails
APP_URL=http://localhost:3000

# Email (Gmail SMTP, like speciarium). Leave USER/PASSWORD empty in dev to log
# emails to the console instead of sending them.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
