# Production env for docker-compose.prod.yml.
# Copy to .env on the server (or store the whole file as the ENV_FILE GitHub
# secret used by the deploy workflow).

# --- Web build (baked into the JS bundle at docker build time) ---
EXPO_PUBLIC_API_URL=https://flowpedia-api.julsql.fr

# --- Host ports (loopback only; the host nginx reverse-proxies these) ---
WEB_PORT=8110
API_PORT=8111

# --- API ---
# Required by Wikimedia — use a valid contact.
WIKIPEDIA_USER_AGENT=Flowpedia/0.1 (https://flowpedia.julsql.fr; contact@flowpedia.julsql.fr)
WIKIPEDIA_LANG=fr
ARTICLE_CACHE_TTL=86400

# --- Postgres (user-signal persistence) ---
POSTGRES_USER=flowpedia
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=flowpedia
