{
  "expo": {
    "name": "Flowpedia",
    "slug": "flowpedia",
    "scheme": "flowpedia",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#121110",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121110"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.flowpedia.mobile"
    },
    "android": {
      "package": "app.flowpedia.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121110"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": ["expo-router", "expo-localization"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
