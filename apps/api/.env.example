# API HTTP port
PORT=3000

# User-Agent required by Wikimedia (use a valid contact)
WIKIPEDIA_USER_AGENT=Flowpedia/0.1 (https://github.com/JulSql/flowpedia; contact@flowpedia.julsql.fr)

# Default Wikipedia content language (overridable per request via ?lang=)
WIKIPEDIA_LANG=fr

# Article cache TTL in seconds
ARTICLE_CACHE_TTL=86400

# Connections (next steps)
DATABASE_URL=postgresql://flowpedia:flowpedia@localhost:5433/flowpedia
REDIS_URL=redis://localhost:6379

# Auth — bearer token signing (CHANGE in production)
JWT_SECRET=flowpedia-dev-secret-change-me
JWT_EXPIRES_IN=30d
# Base URL used to build the password-reset link in emails. In PRODUCTION set
# this to the APP's web origin (where the /reset/<uid>/<token> screen is served,
# e.g. https://flowpedia.app), NOT the API — otherwise the emailed link won't
# open the reset screen.
APP_URL=http://localhost:3000

# Email (Gmail SMTP).
#   Dev (default): leave USER/PASSWORD EMPTY → reset links are logged to the
#   console instead of being sent (zero-config, the API runs without email infra).
#   Real sending: set USER to a Gmail address and PASSWORD to a Gmail *app
#   password* (https://myaccount.google.com/apppasswords — not your login password).
# Example once filled:
#   EMAIL_HOST_USER=you@gmail.com
#   EMAIL_HOST_PASSWORD=abcd efgh ijkl mnop
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
